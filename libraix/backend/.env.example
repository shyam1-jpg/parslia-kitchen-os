NODE_ENV=development
PORT=3001
SESSION_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:5173
DATABASE_PATH=./data/libraix.db

# ── OpenAI (required for live chat) ──
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o
OPENAI_MODEL_SMART=gpt-4o
OPENAI_MODEL_ADVANCED=o3-mini
OPENAI_MODEL_IMAGE=dall-e-3
OPENAI_MODEL_IMAGE_FAST=dall-e-2
OPENAI_IMAGE_SPEED=fast
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ── DeepSeek (https://platform.deepseek.com) ──
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Google Gemini (https://aistudio.google.com/apikey) ──
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ── Anthropic Claude (https://console.anthropic.com) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_MODEL_SMART=claude-3-5-sonnet-20241022

# ── xAI Grok (https://console.x.ai) ──
XAI_API_KEY=
XAI_MODEL_FAST=grok-4-1-fast-non-reasoning
XAI_MODEL_SMART=grok-4-5
XAI_BASE_URL=https://api.x.ai

# ── Web search (optional — improves Deep Research) ──
SERPER_API_KEY=
SEARCH_API_KEY=

# ── Email (password reset + verification) — use Resend OR SMTP ──
EMAIL_FROM=Libraix <noreply@libraix.ai>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Stripe (Pro checkout + subscription management) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ── Company / legal ──
COMPANY_ADDRESS=23 Lincoln Road, Branston, Lincoln LN4 1PE, United Kingdom
COMPANY_LEGAL_NAME=Libraix (trading name — legal entity to be confirmed)
COMPANY_COUNTRY=United Kingdom

# ── Owner seed (production: set on Render, run npm run seed:owner) ──
OWNER_EMAIL=shyam_1@hotmail.co.uk
OWNER_INITIAL_PASSWORD=

# ── Ollama (local models) ──
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.2

# ── OAuth (Google / Microsoft / Apple) ──
# Redirect URI to register with each provider:
#   https://libraix.ai/api/auth/oauth/google/callback
#   https://libraix.ai/api/auth/oauth/microsoft/callback
#   https://libraix.ai/api/auth/oauth/apple/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM private key from Apple Developer — use \n for newlines in one line, or multiline in Render UI
APPLE_PRIVATE_KEY=
