NODE_ENV=development
PORT=3001
SESSION_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:5173
DATABASE_PATH=./data/libraix.db

# ── OpenAI (required for live chat) ──
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o
OPENAI_MODEL_SMART=gpt-4o
OPENAI_MODEL_ADVANCED=o3-mini
OPENAI_MODEL_IMAGE=dall-e-3
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ── Email (password reset + verification) — use Resend OR SMTP ──
EMAIL_FROM=Libraix <noreply@libraix.ai>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Stripe (Pro checkout + subscription management) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ── Company / legal ──
COMPANY_ADDRESS=23 Lincoln Road, Branston, Lincoln LN4 1PE, United Kingdom
COMPANY_LEGAL_NAME=Libraix (trading name — legal entity to be confirmed)
COMPANY_COUNTRY=United Kingdom

# ── Owner seed (production: set on Render, run npm run seed:owner) ──
OWNER_EMAIL=shyam_1@hotmail.co.uk
OWNER_INITIAL_PASSWORD=

# ── OAuth (coming soon) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
